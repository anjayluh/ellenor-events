APP_NAME="Ellenor Events Coordination System"
ENVIRONMENT=development
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/ellenor_events
AUTH_PROVIDER=supabase
JWT_SECRET=change-me-in-production-or-use-supabase-jwt-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
OTP_EXPIRE_MINUTES=10
OTP_RATE_LIMIT_WINDOW_MINUTES=15
OTP_RATE_LIMIT_MAX_ATTEMPTS=5
DEVELOPMENT_OTP_CODE=000000
ALLOW_DEV_AUTH_HEADERS=false
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000
WHATSAPP_MODE=manual_links
EMAIL_PROVIDER=resend
RESEND_API_KEY=
RESEND_FROM_EMAIL="Ellenor Events <noreply@ellenor.events>"
WHATSAPP_CLOUD_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
NOTIFICATION_MAX_ATTEMPTS=3
