APP_NAME="Ellenor Events Coordination System"
ENVIRONMENT=development
DATABASE_URL=postgresql+psycopg://postgres:postgres@db.your-project-ref.supabase.co:5432/postgres
DATABASE_POOLER_URL=postgresql://postgres.your-project-ref:postgres@aws-0-region.pooler.supabase.com:6543/postgres
AUTH_PROVIDER=supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=replace-with-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key
SUPABASE_JWT_SECRET=replace-with-supabase-jwt-secret
JWT_SECRET=change-me-in-production-or-use-supabase-jwt-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ALLOW_DEV_AUTH_HEADERS=false
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000
WHATSAPP_MODE=manual_links
EMAIL_PROVIDER=resend
RESEND_API_KEY=
RESEND_FROM_EMAIL="Ellenor Events <noreply@ellenor.events>"
WHATSAPP_CLOUD_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
NOTIFICATION_MAX_ATTEMPTS=3
TESTER_EMAIL=qa@example.com
TESTER_PASSWORD=replace-with-confirmed-supabase-password
